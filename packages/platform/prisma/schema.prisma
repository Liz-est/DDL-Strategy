// SQLite 环境配置模板
generator client {
  provider = "prisma-client"
	// 指定输出到源码目录，否则 prisma 会默认将 client 构建在 node_modules 中，不利于 docker 部署
	output   = "./generated"
	// 临时修复 Prisma 实例初始化失败的问题：https://github.com/prisma/prisma/issues/27079
	generatedFileExtension = "ts"
	importFileExtension = "ts"
}

datasource db {
  provider = "mysql"
}

model DifyApp {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 应用基本信息
  name        String
  mode        String?
  description String?
  tags        String? // JSON 字符串存储数组

  // 应用状态：1-启用，2-禁用
  isEnabled Int? @default(1) @map("is_enabled")

  // 请求配置
  apiBase String @map("api_base")
  apiKey  String @map("api_key")

  // 回复表单配置
  enableAnswerForm     Boolean @default(false) @map("enable_answer_form")
  answerFormFeedbackText String? @map("answer_form_feedback_text")

  // 输入参数配置
  enableUpdateInputAfterStarts Boolean @default(false) @map("enable_update_input_after_starts")

  // 扩展配置
  openingStatementDisplayMode String? @map("opening_statement_display_mode") // 'default' | 'always'
  enableAnnotation Boolean @default(false) @map("enable_annotation")

  @@map("dify_apps")
}

model AcademicTask {
  id         String   @id
  userId     String   @map("user_id")
  title      String
  startAt    DateTime? @map("start_at")
  endAt      DateTime? @map("end_at")
  isAllDay   Boolean? @default(true) @map("is_all_day")
  dueDate    String?  @map("due_date")
  weight     Float?
  type       String?
  courseCode String?  @map("course_code")
  courseName String?  @map("course_name")
  detail     String?  @db.Text
  sourceQuote String? @map("source_quote") @db.Text
  pageNumbersJson String? @map("page_numbers_json") @db.LongText
  estimatedHours Float? @map("estimated_hours")
  rationale  String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("academic_tasks")
}

/// Personal / non-academic calendar items (chores, errands, life admin).
model ChoreTask {
  id       String    @id
  userId   String    @map("user_id")
  title    String
  startAt  DateTime? @map("start_at")
  endAt    DateTime? @map("end_at")
  isAllDay Boolean?  @default(true) @map("is_all_day")
  priority String?
  location String?
  detail   String?   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId], map: "chore_tasks_user_id_idx")
  @@map("chore_tasks")
}

// 文档处理结果 - 存储前端返回的完整JSON数据
model ProcessingResult {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  courseCode  String?  @map("course_code")
  
  // 存储完整的JSON数据（以JSON字符串形式存储）
  rawData     String   @db.LongText @map("raw_data")    // 前端返回的完整JSON
  processedAt DateTime @default(now()) @map("processed_at")
  
  // 元数据
  sourceType  String?  @map("source_type")              // "academic" | "document" | "custom"
  description String?  @db.Text
  adviceText  String?  @db.LongText @map("advice_text")
  courseSummaryJson String? @db.LongText @map("course_summary_json")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  snapshots   IngestionSnapshot[]

  @@map("processing_results")
}

model AcademicCourse {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  courseCode        String   @map("course_code")
  name              String?
  courseName        String?  @map("course_name")
  description       String?  @db.LongText
  sourceQuote       String?  @map("source_quote") @db.LongText
  rawCourseInfoJson String?  @map("raw_course_info_json") @db.LongText
  /// 0-100: when set, overrides computed completion on planner cards
  manualCompletionRate Int?  @map("manual_completion_rate")
  /// 0-100: when set and this course is selected, overrides semester progress display
  manualSemesterProgress Int? @map("manual_semester_progress")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  policies          CoursePolicy[]
  snapshots         IngestionSnapshot[]

  @@unique([userId, courseCode], map: "academic_courses_user_id_course_code_key")
  @@map("academic_courses")
}

model CoursePolicy {
  id             String   @id
  courseId       String?  @map("course_id")
  userId         String   @map("user_id")
  courseCode     String   @map("course_code")
  latePolicy     String?  @map("late_policy") @db.LongText
  absencePolicy  String?  @map("absence_policy") @db.LongText
  gradingNotes   String?  @map("grading_notes") @db.LongText
  rawPolicyText  String?  @map("raw_policy_text") @db.LongText
  extensionRule  String?  @map("extension_rule") @db.Text
  integrityRule  String?  @map("integrity_rule") @db.Text
  collaborationRule String? @map("collaboration_rule") @db.Text
  examAidRule    String?  @map("exam_aid_rule") @db.Text
  parsedPolicyJson String? @map("parsed_policy_json") @db.LongText
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  course         AcademicCourse? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  rules          CoursePolicyRule[]

  @@unique([userId, courseCode], map: "course_policies_user_id_course_code_key")
  @@map("course_policies")
}

model CoursePolicyRule {
  id             String   @id @default(cuid())
  policyId       String   @map("policy_id")
  ruleType       String   @map("rule_type")
  thresholdValue Float?   @map("threshold_value")
  penaltyPercent Float?   @map("penalty_percent")
  timeUnit       String?  @map("time_unit")
  rawQuote       String?  @map("raw_quote") @db.LongText
  ruleOrder      Int?     @map("rule_order")
  createdAt      DateTime @default(now()) @map("created_at")
  policy         CoursePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId], map: "course_policy_rules_policy_id_idx")
  @@map("course_policy_rules")
}

model IngestionSnapshot {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  courseCode       String?  @map("course_code")
  courseId         String?  @map("course_id")
  processingResultId String? @map("processing_result_id")
  sourceType       String?  @map("source_type")
  rawJson          String   @map("raw_json") @db.LongText
  reportText       String?  @map("report_text") @db.LongText
  parsedPolicyJson String?  @map("parsed_policy_json") @db.LongText
  createdAt        DateTime @default(now()) @map("created_at")
  course           AcademicCourse? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  processingResult ProcessingResult? @relation(fields: [processingResultId], references: [id], onDelete: SetNull)

  @@index([userId], map: "ingestion_snapshots_user_id_idx")
  @@index([courseId], map: "ingestion_snapshots_course_id_idx")
  @@map("ingestion_snapshots")
}

// 用户表 - 仅用于后台管理员账户
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String   // 密码哈希
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
